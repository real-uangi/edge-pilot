FROM debian:bookworm-slim

RUN groupadd --system --gid 10001 edgepilot \
    && useradd --system --uid 10001 --gid edgepilot --home-dir /var/lib/edge-pilot --create-home --shell /usr/sbin/nologin edgepilot

WORKDIR /var/lib/edge-pilot

COPY --chown=edgepilot:edgepilot edge-pilot-agent /usr/local/bin/edge-pilot-agent

USER edgepilot:edgepilot

ENTRYPOINT ["/usr/local/bin/edge-pilot-agent"]
